# Core
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
FRONTEND_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql+psycopg2://launchpath:launchpath@localhost:5432/launchpath

# AI (leave blank to use deterministic mock)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Background jobs
REDIS_URL=redis://localhost:6379/0

# Job source adapters + real-web search (SerpApi: https://serpapi.com)
# SERPAPI_KEY also powers the "real interview questions" search — without it, that feature
# returns an honest "connect a key" note instead of fabricating sources.
ENABLED_ADAPTERS=sample
SERPAPI_KEY=

# Email notifications (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=LaunchPath <noreply@launchpath.app>

# Clerk auth (leave blank to use dev credential login)
CLERK_JWKS_URL=
CLERK_ISSUER=
